// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 枚举定义 ====================

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
  DELETED
}

enum Gender {
  UNKNOWN
  MALE
  FEMALE
}

enum StudentVerifyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RoleType {
  SUPER_ADMIN
  ADMIN
  REGION_ADMIN
  MERCHANT
  RIDER
  USER
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  VOTE
  REPOST
}

enum PostStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  DELETED
  TOP
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

enum CircleMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum CircleJoinType {
  OPEN
  APPLY
  INVITE
}

enum OrderStatus {
  PENDING_PAY
  PAID
  SHIPPED
  DELIVERED
  RECEIVED
  COMPLETED
  CANCELLED
  REFUNDING
  REFUNDED
}

enum DeliveryOrderStatus {
  PENDING_PAY
  PENDING_ACCEPT
  ACCEPTED
  IN_PROGRESS
  ARRIVED
  COMPLETED
  CANCELLED
  REFUNDING
  REFUNDED
}

enum DeliveryTaskType {
  PICKUP
  DELIVER
  MEAL
  UNIVERSAL
}

enum RiderStatus {
  OFFLINE
  ONLINE
  BUSY
}

enum WalletType {
  BALANCE
  FREEZE
}

enum TransactionType {
  RECHARGE
  WITHDRAW
  PAY
  REFUND
  REWARD
  TRANSFER_IN
  TRANSFER_OUT
  COMMISSION
  PENALTY
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum WithdrawStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REJECTED
}

enum PaymentChannel {
  WX_PAY
  ALI_PAY
  BALANCE
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
  LOCATION
  SYSTEM
}

enum NotificationType {
  SYSTEM
  LIKE
  COMMENT
  FOLLOW
  ORDER
  DELIVERY
  WALLET
  CIRCLE
}

enum CouponType {
  FULL_REDUCTION
  DISCOUNT
  EXCHANGE
}

enum CheckInType {
  DAILY
  CONTINUOUS
}

enum SecondHandStatus {
  ON_SALE
  SOLD
  OFFLINE
}

enum MatchStatus {
  PENDING
  MATCHED
  REJECTED
  EXPIRED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  BAN
  UNBAN
}

enum PriceAdjustmentType {
  PERCENTAGE
  FIXED
}

enum PriceAdjustmentScope {
  REGION
  CATEGORY
  MERCHANT
}

// ==================== 用户与权限 ====================

model User {
  id          String     @id @default(cuid())
  openid      String     @unique
  unionid     String?
  avatar      String?
  nickname    String?
  phone       String?
  status      UserStatus @default(ACTIVE)
  userType    Int        @default(1) // 1=normal user, 4=bot
  muteEndAt   DateTime?
  muteReason  String?
  lastLoginAt DateTime?
  lastLoginIp String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  // Relations
  profile               UserProfile?
  settings              UserSettings?
  studentVerify         StudentVerify?
  roles                 UserRole[]
  posts                 Post[]
  comments              Comment[]
  likes                 Like[]
  favorites             Favorite[]
  follows               Follow[]                 @relation("UserFollows")
  followers             Follow[]                 @relation("UserFollowers")
  blocks                Block[]                  @relation("UserBlocks")
  blockedBy             Block[]                  @relation("UserBlockedBy")
  browseHistory         BrowseHistory[]
  tags                  UserTag[]
  experiences           UserExperience[]
  circles               CircleMember[]
  circlePayments        CirclePayment[]
  cartItems             Cart[]
  orders                Order[]                  @relation("UserOrders")
  deliveryOrders        DeliveryOrder[]          @relation("UserDeliveryOrders")
  riderOrders           DeliveryOrder[]          @relation("RiderDeliveryOrders")
  wallet                Wallet?
  transactions          WalletTransaction[]
  withdraws             Withdraw[]
  messages              Message[]                @relation("SenderMessages")
  conversations         ConversationMember[]
  notifications         Notification[]
  coupons               CouponReceive[]
  checkIns              CheckIn[]
  badges                UserBadge[]
  activityJoins         ActivityJoin[]
  competitionPhotos     CompetitionPhoto[]
  competitionVotes      CompetitionPhotoVote[]
  competitionRatings    CompetitionPhotoRating[]
  activityClubMembers   ActivityClubMember[]
  secondHands           SecondHand[]
  driftBottles          DriftBottle[]
  matches               Match[]                  @relation("UserMatches")
  matchTargets          Match[]                  @relation("TargetMatches")
  netDisks              NetDisk[]
  postCollaborators     PostCollaborator[]
  reviews               Review[]
  reports               Report[]                 @relation("Reporter")
  reported              Report[]                 @relation("Reported")
  auditLogs             AuditLog[]
  addresses             Address[]
  titleRecords          UserTitleRecord[]
  datingProfile         DatingProfile?
  netDiskResources      NetDiskResource[]
  netDiskDownloads      NetDiskDownload[]
  netDiskComments       NetDiskComment[]
  stickers              Sticker[]
  inviterInvites        ShareInvite[]        @relation("InviterRelation")
  inviteeInvites        ShareInvite[]        @relation("InviteeRelation")
  shareRewards          ShareReward[]
  punchInRecords        PunchInRecord[]
  punchInWishlists      PunchInWishlist[]
  punchInComments       PunchInComment[]
  userRatings           UserRating[]
  mallOrders            MallOrder[]
  mallReviews           MallReview[]
  distributor           MallDistributor?
  groupBuyOrders        GroupBuyOrder[]
  groupBuyReviews       GroupBuyReview[]
  alipayTransfers       AlipayTransfer[]     @relation("OperatorAlipayTransfers")
  regionBalanceLogs     RegionBalanceLog[]   @relation("OperatorRegionBalanceLogs")
  activityOrders        ActivityOrder[]
  secondHandOrders      SecondHandOrder[]
  topupOrders           TopupOrder[]
  errandOrders          ErrandOrder[]
  datingOrders          DatingOrder[]
  datingReportsFiled    DatingReport[]         @relation("DatingReporter")
  datingReportsAgainst  DatingReport[]         @relation("DatingReported")
  communityPayments     CommunityPayment[]
  incentiveRecords      IncentiveRecord[]
  regionRiders          RegionRider[]
  cityAgent             CityAgent?
  cityAgentApplications CityAgentApplication[]
  transferRequests      TransferRequest[]
  botAccount            BotAccount?
  photoContestEntries   PhotoContestEntry[]
  photoContestRatings   PhotoContestRating[]
  ratingReplies         RatingReply[]

  @@index([openid])
  @@index([phone])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model UserProfile {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gender    Gender    @default(UNKNOWN)
  birthday  DateTime?
  bio       String?
  region    String?
  school    String?
  major     String?
  grade     String?
  dormitory String?
  wechat    String?
  qq        String?
  email     String?
  realName  String?
  idCard    String?
  updatedAt DateTime  @updatedAt

  @@map("user_profiles")
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  privacyLevel     Int      @default(0) // 0:公开 1:粉丝 2:互关 3:私密
  allowFollow      Boolean  @default(true)
  allowComment     Boolean  @default(true)
  allowMessage     Boolean  @default(true)
  showOnlineStatus Boolean  @default(true)
  notifyLike       Boolean  @default(true)
  notifyComment    Boolean  @default(true)
  notifyFollow     Boolean  @default(true)
  notifySystem     Boolean  @default(true)
  notifyOrder      Boolean  @default(true)
  language         String   @default("zh-CN")
  updatedAt        DateTime @updatedAt

  @@map("user_settings")
}

model StudentVerify {
  id         String              @id @default(cuid())
  userId     String              @unique
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  realName   String
  idCard     String?
  studentId  String
  schoolName String
  major      String?
  grade      String?
  cardImage  String?
  status     StudentVerifyStatus @default(PENDING)
  remark     String?
  verifiedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@map("student_verifies")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  type        RoleType
  description String?
  permissions Permission[]
  users       UserRole[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  module      String
  action      String
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())

  @@map("permissions")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  regionId  String?
  region    Region?  @relation(fields: [regionId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@unique([userId, roleId, regionId])
  @@map("user_roles")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

model Block {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserBlocks", fields: [userId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("UserBlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, blockedId])
  @@map("blocks")
}

model BrowseHistory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String // post, product, circle, second_hand
  targetId   String
  title      String?
  image      String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([targetType, targetId])
  @@map("browse_histories")
}

model UserTag {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  createdAt DateTime @default(now())

  @@unique([userId, name])
  @@map("user_tags")
}

// ==================== 区域系统 ====================

model Region {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  cover       String?
  logo        String?
  address     String?
  latitude    Float?
  longitude   Float?
  radius      Int      @default(5000) // 距离限制，单位米
  distanceLimit Int?   @default(0) // 0=关闭距离限制
  studentOnly Boolean  @default(false)
  isOpen      Boolean  @default(true)
  sortOrder   Int      @default(0)
  settings    Json? // 区域配置(保留兼容)

  // 基础信息
  regionType       String?  @default("other") // campus / community / other
  isHot            Boolean  @default(false)
  regionCoverMode  String?  @default("cover") // cover / popup

  // 财务配置
  balance         Decimal? @default(0) @db.Decimal(12,2)
  minWithdraw     Decimal? @default(0) @db.Decimal(10,2)
  maxWithdraw     Decimal? @default(0) @db.Decimal(10,2)
  withdrawFee     Decimal? @default(0) @db.Decimal(10,2)
  withdrawRate    Decimal? @default(0) @db.Decimal(5,4)
  commissionRate  Decimal? @default(0) @db.Decimal(5,4)
  selfUnbanFee    Decimal? @default(0) @db.Decimal(10,2)
  // 财务：区域累计佣金
  totalCommission Decimal? @default(0) @db.Decimal(12,2)

  // 显示设置
  showHotList                 Boolean  @default(false)
  hotFeaturedDisplay          String?  @default("none") // none / hot / featured / mixed
  isForceGuidance             Boolean  @default(false)
  privateMessageEnabled       Boolean  @default(true)
  contactsRequireStudentAuth  Boolean  @default(false)
  onlyStudentAuthUsers        Boolean  @default(false)
  groupChatEnabled            Boolean  @default(false)
  enableQrcodeFilter          Boolean  @default(false)

  // 页面布局
  homeNavLayout       Int?     @default(1) // 1-9
  messagePageLayout   String?  @default("default") // default / xiaohongshu
  profilePageLayout   String?  @default("default")

  // 复杂 JSON 配置
  carouselImages      Json?
  regionTabs          Json?
  homeLeaderboard     Json?
  messageIcons        Json?
  messageNavigation   Json?
  profileLayoutItems  Json?
  homeNavLayoutConfig Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  admins          UserRole[]
  banners         RegionBanner[]
  notices         RegionNotice[]
  navs            RegionNav[]
  tabBar          RegionTabBar?
  posts           Post[]
  circles         Circle[]
  merchants       Merchant[]
  deliveryConfigs DeliveryConfig[]
  activities      Activity[]
  secondHands     SecondHand[]
  cityAgents       CityAgent[]
  cityAgentApps    CityAgentApplication[]
  priceAdjustments ProductPriceAdjustment[]
  merchantSettings         RegionMerchantSettings?
  secondHandRegionSetting  SecondHandRegionSetting?
  coupons                  Coupon[]
  datingPackages           DatingPackage[]
  balanceLogs              RegionBalanceLog[]

  @@map("regions")
}

model RegionBanner {
  id        String    @id @default(cuid())
  regionId  String
  region    Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)
  title     String?
  image     String
  link      String?
  sortOrder Int       @default(0)
  isShow    Boolean   @default(true)
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("region_banners")
}

model RegionNotice {
  id        String    @id @default(cuid())
  regionId  String
  region    Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String    @default("normal") // normal, important, emergency
  isTop     Boolean   @default(false)
  isShow    Boolean   @default(true)
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("region_notices")
}

model RegionNav {
  id        String   @id @default(cuid())
  regionId  String
  region    Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  name      String
  icon      String
  link      String
  type      String   @default("page") // page, miniapp, web
  sortOrder Int      @default(0)
  isShow    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("region_navs")
}

model RegionTabBar {
  id        String   @id @default(cuid())
  regionId  String   @unique
  region    Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  config    Json // TabBar 配置
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("region_tab_bars")
}

// ==================== 内容社区 ====================

model Post {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  regionId      String?
  region        Region?    @relation(fields: [regionId], references: [id], onDelete: SetNull)
  type          PostType   @default(TEXT)
  status        PostStatus @default(PENDING)
  title         String?
  content       String     @db.Text
  location      String?
  latitude      Float?
  longitude     Float?
  viewCount     Int        @default(0)
  likeCount     Int        @default(0)
  commentCount  Int        @default(0)
  favoriteCount Int        @default(0)
  shareCount    Int        @default(0)
  isTop         Boolean    @default(false)
  topExpireAt   DateTime?
  isCoCreate    Boolean    @default(false)
  auditStatus   String     @default("pending") // pending, approved, rejected
  auditReason   String?
  isEssence     Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  // Relations
  media         PostMedia[]
  topics        PostTopic[]
  comments      Comment[]
  likes         Like[]
  favorites     Favorite[]
  votes         Vote[]
  collaborators PostCollaborator[]
  reports       Report[]

  @@index([userId, createdAt])
  @@index([regionId, status, createdAt])
  @@index([status, isTop, createdAt])
  @@index([type])
  @@map("posts")
}

model PostMedia {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  type      MediaType
  url       String
  thumb     String?
  width     Int?
  height    Int?
  duration  Int? // 视频/音频时长，单位秒
  size      Int? // 文件大小，单位字节
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())

  @@map("post_media")
}

model Topic {
  id          String   @id @default(cuid())
  name        String   @unique
  cover       String?
  description String?
  postCount   Int      @default(0)
  followCount Int      @default(0)
  isHot       Boolean  @default(false)
  sortOrder   Int      @default(0)
  status      String   @default("active") // active, disabled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts   PostTopic[]
  circles CircleTopicGroup[]

  @@map("topics")
}

model PostTopic {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, topicId])
  @@map("post_topics")
}

model Comment {
  id          String    @id @default(cuid())
  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies     Comment[] @relation("CommentReplies")
  content     String
  likeCount   Int       @default(0)
  isTop       Boolean   @default(false)
  status      String    @default("active") // active, hidden, deleted
  auditStatus String    @default("pending") // pending, approved, rejected
  auditReason String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([postId, createdAt])
  @@index([parentId])
  @@map("comments")
}

model Like {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String // post, comment
  targetId   String
  createdAt  DateTime @default(now())

  post Post? @relation(fields: [targetId], references: [id], onDelete: Cascade, map: "like_post_fk")

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("likes")
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String // post, product, second_hand
  targetId   String
  createdAt  DateTime @default(now())

  post Post? @relation(fields: [targetId], references: [id], onDelete: Cascade, map: "favorite_post_fk")

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("favorites")
}

model Vote {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  title     String
  options   Json // [{id, text, count}]
  maxSelect Int       @default(1)
  endAt     DateTime?
  createdAt DateTime  @default(now())

  @@map("votes")
}

model VoteRecord {
  id        String   @id @default(cuid())
  voteId    String
  userId    String
  options   Json // [optionId]
  createdAt DateTime @default(now())

  @@unique([voteId, userId])
  @@map("vote_records")
}

model PostCollaborator {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("post_collaborators")
}

model Report {
  id         String    @id @default(cuid())
  reporterId String
  reporter   User      @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedId String?
  reported   User?     @relation("Reported", fields: [reportedId], references: [id], onDelete: SetNull)
  targetType String // post, comment, user, message, merchant
  targetId   String
  reason     String
  detail     String?
  images     Json?
  status     String    @default("pending") // pending, processing, resolved, rejected
  result     String?
  handlerId  String?
  handledAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  post Post? @relation(fields: [targetId], references: [id], onDelete: Cascade, map: "report_post_fk")

  @@index([targetType, targetId])
  @@index([status])
  @@map("reports")
}

// ==================== 圈子系统 ====================

model Circle {
  id          String         @id @default(cuid())
  name        String
  icon        String?
  cover       String?
  description String?
  regionId    String?
  region      Region?        @relation(fields: [regionId], references: [id], onDelete: SetNull)
  joinType    CircleJoinType @default(OPEN)
  isOfficial  Boolean        @default(false)
  memberCount Int            @default(0)
  postCount   Int            @default(0)
  maxMembers  Int            @default(500)
  tags        Json?
  status      String         @default("active") // active, dissolved
  price       Decimal?       @db.Decimal(10, 2)
  paidJoin    Boolean        @default(false)
  inviteCode  String?
  deadline    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  members     CircleMember[]
  channels    CircleChannel[]
  topicGroups CircleTopicGroup[]
  payments    CirclePayment[]

  @@map("circles")
}

model CircleMember {
  id         String           @id @default(cuid())
  circleId   String
  circle     Circle           @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       CircleMemberRole @default(MEMBER)
  nickName   String?
  joinAt     DateTime         @default(now())
  lastReadAt DateTime?

  @@unique([circleId, userId])
  @@map("circle_members")
}

model CircleChannel {
  id        String   @id @default(cuid())
  circleId  String
  circle    Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  name      String
  type      String   @default("text") // text, voice, notice
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("circle_channels")
}

model CircleTopicGroup {
  id        String   @id @default(cuid())
  circleId  String
  circle    Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([circleId, topicId])
  @@map("circle_topic_groups")
}

model CirclePayment {
  id          String    @id @default(cuid())
  circleId    String
  circle      Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal   @db.Decimal(10, 2)
  payChannel  String?
  status      String    @default("pending") // pending, paid, refunded
  payTime     DateTime?
  createdAt   DateTime  @default(now())

  @@map("circle_payments")
}

// ==================== 商家/商城 ====================

model Merchant {
  id             String   @id @default(cuid())
  userId         String
  regionId       String?
  region         Region?  @relation(fields: [regionId], references: [id], onDelete: SetNull)
  name           String
  logo           String?
  cover          String?
  phone          String?
  contactPerson  String?
  address        String?
  latitude       Float?
  longitude      Float?
  businessHours  String?
  description    String?
  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  status         String   @default("pending") // pending, approved, rejected, closed
  rejectReason   String?
  rating         Float    @default(5)
  saleCount      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products         Product[]
  orders           Order[]
  freightTemplates FreightTemplate[]
  settlements      MerchantSettlement[]
  priceAdjustments ProductPriceAdjustment[]
  groupBuyPackages GroupBuyPackage[]
  coupons          Coupon[]

  @@map("merchants")
}

model Category {
  id        String    @id @default(cuid())
  parentId  String?
  parent    Category? @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  name      String
  icon      String?
  sortOrder Int       @default(0)
  isShow    Boolean   @default(true)
  type      String    @default("product") // product, post, circle
  status    String    @default("active") // active, disabled, deleted
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  children         Category[]                 @relation("CategoryChildren")
  products         Product[]
  merchants        Merchant[]
  priceAdjustments ProductPriceAdjustment[]

  @@map("categories")
}

model Product {
  id          String    @id @default(cuid())
  merchantId  String
  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name        String
  images      Json
  detail      String?   @db.Text
  price       Decimal   @db.Decimal(10, 2)
  originPrice Decimal?  @db.Decimal(10, 2)
  stock       Int       @default(0)
  saleCount   Int       @default(0)
  unit        String?
  weight      Int? // 单位克
  status      String    @default("on_sale") // on_sale, off_sale, deleted
  isHot       Boolean   @default(false)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  skus       SKU[]
  cartItems  Cart[]
  orderItems OrderItem[]
  reviews    Review[]
  promotions PromotionProduct[]

  @@index([merchantId, status])
  @@index([categoryId])
  @@map("products")
}

model SKU {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  specs       Json // [{key: "颜色", value: "红色"}]
  price       Decimal  @db.Decimal(10, 2)
  originPrice Decimal? @db.Decimal(10, 2)
  stock       Int      @default(0)
  image       String?
  status      String   @default("on_sale")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems  Cart[]
  orderItems OrderItem[]

  @@map("skus")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  skuId     String?
  sku       SKU?     @relation(fields: [skuId], references: [id], onDelete: SetNull)
  quantity  Int      @default(1)
  selected  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, skuId])
  @@map("carts")
}

model Order {
  id              String          @id @default(cuid())
  orderNo         String          @unique
  userId          String
  user            User            @relation("UserOrders", fields: [userId], references: [id], onDelete: Cascade)
  merchantId      String
  merchant        Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  status          OrderStatus     @default(PENDING_PAY)
  totalAmount     Decimal         @db.Decimal(10, 2)
  discountAmount  Decimal         @default(0) @db.Decimal(10, 2)
  freightAmount   Decimal         @default(0) @db.Decimal(10, 2)
  payAmount       Decimal         @db.Decimal(10, 2)
  payChannel      PaymentChannel?
  payTime         DateTime?
  deliverTime     DateTime?
  receiveTime     DateTime?
  completeTime    DateTime?
  cancelTime      DateTime?
  cancelReason    String?
  remark          String?
  receiverName    String
  receiverPhone   String
  receiverAddress String
  trackingNo      String?
  trackingCompany String?
  refundStatus    String          @default("none") // none, refunding, refunded
  refundAmount    Decimal?        @db.Decimal(10, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items     OrderItem[]
  refunds   Refund[]
  reviews   Review[]
  orderLogs OrderLog[]

  @@index([userId, createdAt])
  @@index([merchantId, status])
  @@index([orderNo])
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  skuId        String?
  sku          SKU?    @relation(fields: [skuId], references: [id], onDelete: SetNull)
  productName  String
  productImage String
  skuSpecs     Json?
  price        Decimal @db.Decimal(10, 2)
  quantity     Int
  totalPrice   Decimal @db.Decimal(10, 2)

  @@map("order_items")
}

model Refund {
  id           String    @id @default(cuid())
  orderId      String
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refundNo     String    @unique
  amount       Decimal   @db.Decimal(10, 2)
  reason       String
  images       Json?
  status       String    @default("pending") // pending, approved, rejected, completed
  rejectReason String?
  refundTime   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("refunds")
}

model Review {
  id          String    @id @default(cuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  merchantId  String?
  rating      Int       @default(5)
  content     String?
  images      Json?
  isAnonymous Boolean   @default(false)
  reply       String?
  replyAt     DateTime?
  createdAt   DateTime  @default(now())

  @@map("reviews")
}

model Promotion {
  id        String   @id @default(cuid())
  name      String
  type      String // full_reduction, discount
  rules     Json // {full: 100, reduction: 10}
  startAt   DateTime
  endAt     DateTime
  isGlobal  Boolean  @default(false)
  status    String   @default("active")
  createdAt DateTime @default(now())

  products PromotionProduct[]

  @@map("promotions")
}

model PromotionProduct {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promotionId, productId])
  @@map("promotion_products")
}

model FreightTemplate {
  id         String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  name       String
  rules      Json // [{region: [], firstWeight: 1000, firstPrice: 10, continueWeight: 500, continuePrice: 5}]
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("freight_templates")
}

// ==================== 外卖/跑腿 ====================

model DeliveryConfig {
  id            String           @id @default(cuid())
  regionId      String
  region        Region           @relation(fields: [regionId], references: [id], onDelete: Cascade)
  type          DeliveryTaskType
  basePrice     Decimal          @db.Decimal(10, 2)
  distancePrice Decimal          @db.Decimal(10, 2) // 每公里价格
  weightPrice   Decimal          @default(0) @db.Decimal(10, 2)
  timePrice     Decimal          @default(0) @db.Decimal(10, 2)
  nightPrice    Decimal          @default(0) @db.Decimal(10, 2)
  maxDistance   Int              @default(10) // 公里
  maxWeight     Int              @default(20) // 公斤
  isOpen        Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([regionId, type])
  @@map("delivery_configs")
}

model DeliveryOrder {
  id             String              @id @default(cuid())
  orderNo        String              @unique
  userId         String
  user           User                @relation("UserDeliveryOrders", fields: [userId], references: [id], onDelete: Cascade)
  riderId        String?
  rider          User?               @relation("RiderDeliveryOrders", fields: [riderId], references: [id], onDelete: SetNull)
  type           DeliveryTaskType
  status         DeliveryOrderStatus @default(PENDING_PAY)
  title          String
  description    String?
  pickupAddress  String
  pickupContact  String?
  pickupPhone    String?
  pickupLat      Float?
  pickupLng      Float?
  deliverAddress String
  deliverContact String?
  deliverPhone   String?
  deliverLat     Float?
  deliverLng     Float?
  weight         Float? // 公斤
  distance       Float? // 公里
  price          Decimal             @db.Decimal(10, 2)
  tip            Decimal             @default(0) @db.Decimal(10, 2)
  payChannel     PaymentChannel?
  payTime        DateTime?
  acceptTime     DateTime?
  pickupTime     DateTime?
  deliverTime    DateTime?
  completeTime   DateTime?
  cancelTime     DateTime?
  cancelReason   String?
  refundStatus   String              @default("none")
  refundAmount   Decimal?            @db.Decimal(10, 2)
  images         Json?
  remark         String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([userId, createdAt])
  @@index([riderId, status])
  @@index([status, createdAt])
  @@map("delivery_orders")
}

model Rider {
  id                String      @id @default(cuid())
  userId            String      @unique
  realName          String
  idCard            String
  phone             String
  status            RiderStatus @default(OFFLINE)
  verifyStatus      String      @default("pending") // pending, approved, rejected
  rating            Float       @default(5)
  totalOrders       Int         @default(0)
  todayOrders       Int         @default(0)
  lat               Float?
  lng               Float?
  locationUpdatedAt DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("riders")
}

// ==================== 财务系统 ====================

model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  freeze      Decimal  @default(0) @db.Decimal(12, 2)
  totalIn     Decimal  @default(0) @db.Decimal(12, 2)
  totalOut    Decimal  @default(0) @db.Decimal(12, 2)
  payPassword String?
  updatedAt   DateTime @updatedAt

  @@map("wallets")
}

model WalletTransaction {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Decimal           @db.Decimal(12, 2)
  balance     Decimal           @db.Decimal(12, 2)
  channel     PaymentChannel?
  orderNo     String?
  description String?
  status      TransactionStatus @default(SUCCESS)
  createdAt   DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([type])
  @@map("wallet_transactions")
}

model Withdraw {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal        @db.Decimal(10, 2)
  channel     PaymentChannel
  account     String // 收款账号
  realName    String?
  status      WithdrawStatus @default(PENDING)
  failReason  String?
  transferNo  String? // 转账单号
  processedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId, status])
  @@map("withdraws")
}

model Recharge {
  id        String         @id @default(cuid())
  userId    String
  amount    Decimal        @db.Decimal(10, 2)
  channel   PaymentChannel
  orderNo   String         @unique
  status    String         @default("pending") // pending, success, failed
  payTime   DateTime?
  createdAt DateTime       @default(now())

  @@map("recharges")
}

// ==================== 支付宝转账 ====================

model AlipayTransfer {
  id            String   @id @default(cuid())
  transferNo    String   @unique
  payeeAccount  String
  payeeName     String?
  amount        Decimal  @db.Decimal(10, 2)
  status        String   @default("pending") // pending, processing, success, failed
  failReason    String?
  alipayOrderNo String?
  operatorId    String?
  remark        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  operator      User?    @relation("OperatorAlipayTransfers", fields: [operatorId], references: [id])

  @@map("alipay_transfers")
}

// ==================== 区域余额变动 ====================

model RegionBalanceLog {
  id          String   @id @default(cuid())
  regionId    String
  type        String   // commission, withdraw, adjust, reward
  amount      Decimal  @db.Decimal(10, 2)
  balance     Decimal  @db.Decimal(12, 2)
  orderNo     String?
  description String?
  operatorId  String?
  createdAt   DateTime @default(now())

  region      Region   @relation(fields: [regionId], references: [id])
  operator    User?    @relation("OperatorRegionBalanceLogs", fields: [operatorId], references: [id])

  @@index([regionId, createdAt])
  @@map("region_balance_logs")
}

// ==================== 消息系统 ====================

model Conversation {
  id          String    @id @default(cuid())
  type        String    @default("private") // private, group, circle
  title       String?
  avatar      String?
  lastMessage String?
  lastMsgTime DateTime?
  unreadCount Int       @default(0)
  isBlocked   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members  ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member") // owner, admin, member
  nickName       String?
  unreadCount    Int          @default(0)
  lastReadMsgId  String?
  isMuted        Boolean      @default(false)
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SenderMessages", fields: [senderId], references: [id], onDelete: Cascade)
  type           MessageType
  content        String
  extra          Json? // 额外数据，如图片URL、位置等
  isRecalled     Boolean      @default(false)
  recalledAt     DateTime?
  readCount      Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  content   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

// ==================== 运营功能 ====================

model Coupon {
  id            String     @id @default(cuid())
  name          String
  type          CouponType
  value         Decimal    @db.Decimal(10, 2)
  minAmount     Decimal    @default(0) @db.Decimal(10, 2)
  totalCount    Int
  receivedCount Int        @default(0)
  usedCount     Int        @default(0)
  limitPerUser  Int        @default(1)
  startAt       DateTime
  endAt         DateTime
  status        String     @default("active")
  description   String?
  code          String?    @unique
  regionId      String?
  region        Region?    @relation(fields: [regionId], references: [id], onDelete: SetNull)
  merchantId    String?
  merchant      Merchant?  @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  receives CouponReceive[]

  @@index([status, endAt])
  @@index([regionId])
  @@map("coupons")
}

model CouponReceive {
  id        String    @id @default(cuid())
  couponId  String
  coupon    Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String    @default("unused") // unused, used, expired
  usedAt    DateTime?
  orderNo   String?
  createdAt DateTime  @default(now())

  @@map("coupon_receives")
}

model CheckIn {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           CheckInType @default(DAILY)
  continuousDays Int         @default(1)
  reward         Decimal     @default(0) @db.Decimal(10, 2)
  createdAt      DateTime    @default(now())

  @@unique([userId, createdAt]) // 每日只能签到一次
  @@map("check_ins")
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  icon        String
  description String?
  condition   String // 获取条件描述
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([badgeId, userId])
  @@map("user_badges")
}

model Activity {
  id          String   @id @default(cuid())
  regionId    String?
  region      Region?       @relation(fields: [regionId], references: [id], onDelete: SetNull)
  typeId      String?
  type        ActivityType? @relation(fields: [typeId], references: [id], onDelete: SetNull)
  clubId      String?
  club        ActivityClub? @relation(fields: [clubId], references: [id], onDelete: SetNull)
  title       String
  cover       String?
  description String?       @db.Text
  location    String?
  lat         Float?
  lng         Float?
  startAt     DateTime
  endAt       DateTime
  signStartAt DateTime?
  signEndAt   DateTime?
  maxPeople   Int?
  joinCount   Int           @default(0)
  fee         Decimal?      @db.Decimal(10, 2)
  refundPolicy String?
  visibility  String        @default("public")
  status      String        @default("upcoming") // upcoming, signup, ongoing, ended, cancelled
  organizer   String?
  contact     String?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  joins    ActivityJoin[]
  orders   ActivityOrder[]
  packages ActivityPackage[]
  rewards  ActivityReward[]

  @@index([regionId, status, createdAt])
  @@map("activities")
}

model ActivityJoin {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     String   @default("joined") // joined, cancelled
  createdAt  DateTime @default(now())

  @@unique([activityId, userId])
  @@map("activity_joins")
}

model ActivityType {
  id          String   @id @default(cuid())
  regionId    String?
  name        String
  icon        String?
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activities  Activity[]

  @@index([regionId, sortOrder])
  @@map("activity_types")
}

model ActivityPackage {
  id              String   @id @default(cuid())
  activityId      String
  activity        Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  name            String
  price           Decimal  @db.Decimal(10, 2)
  originalPrice   Decimal? @db.Decimal(10, 2)
  stock           Int      @default(0)
  availableTickets Int     @default(0)
  limitPerUser    Int?
  ticketType      String   @default("single")
  description     String?  @db.Text
  genderLimit     String?
  saleStartAt     DateTime?
  saleEndAt       DateTime?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders ActivityOrder[]

  @@index([activityId, sortOrder])
  @@map("activity_packages")
}

model ActivityReward {
  id          String   @id @default(cuid())
  activityId  String?
  activity    Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)
  regionId    String?
  name        String
  rewardType  String
  rewardValue Decimal? @db.Decimal(10, 2)
  titleId     String?
  quantity    Int      @default(0)
  issuedCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([regionId])
  @@map("activity_rewards")
}

model ActivityTicket {
  id           String        @id @default(cuid())
  orderId      String
  order        ActivityOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  packageId    String?
  activityId   String
  userId       String
  ticketNumber String
  ticketStatus String        @default("valid")
  checkInTime  DateTime?
  checkedInBy  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([activityId, ticketStatus])
  @@index([orderId])
  @@map("activity_tickets")
}

model ActivityCompetition {
  id          String    @id @default(cuid())
  regionId    String?
  title       String
  cover       String?
  description String?   @db.Text
  rules       Json?
  startAt     DateTime?
  endAt       DateTime?
  status      String    @default("active")
  sortOrder   Int       @default(0)
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  photos CompetitionPhoto[]

  @@index([regionId, status, createdAt])
  @@map("activity_competitions")
}

model CompetitionPhoto {
  id            String              @id @default(cuid())
  competitionId String
  competition   ActivityCompetition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String?
  description   String?             @db.Text
