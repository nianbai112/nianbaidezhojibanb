// ==================== 爆照评选 ====================

model PhotoContest {
  id                  String   @id @default(cuid())
  regionId            String?
  title               String
  description         String?  @db.Text
  cover               String?
  rules               Json?
  status              String   @default("draft") // draft, active, voting, ended
  startAt             DateTime?
  endAt               DateTime?
  voteEndAt           DateTime?
  circleId            String?
  createdBy           String?
  maxVotesPerUser     Int      @default(3)
  maxVotesPerDay      Int?
  maxVotesPerPhoto    Int?
  allowSelfVote       Boolean  @default(false)
  allowAnonymousVote  Boolean  @default(false)
  requireCircleMember Boolean  @default(false)
  rewardEnabled       Boolean  @default(false)
  rewardType          String?
  rewardDetails       Json?
  adminNote           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  entries            PhotoContestEntry[]
  winners            PhotoContestWinner[]
  votes              PhotoContestVote[]
  voteRestrictionLogs VoteRestrictionLog[]

  @@index([regionId, status, createdAt])
  @@map("photo_contests")
}

model PhotoContestEntry {
  id           String       @id @default(cuid())
  contestId    String
  contest      PhotoContest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryNumber  Int?
  title        String?
  description  String?      @db.Text
  imageUrl     String
  thumbnailUrl String?
  status       String       @default("pending") // pending, approved, rejected
  rejectReason String?
  approvedAt   DateTime?
  voteCount    Int          @default(0)
  ratingsAvg   Float        @default(0)
  createdAt    DateTime     @default(now())

  votes           PhotoContestVote[]
  ratings         PhotoContestRating[]
  contestWinners  PhotoContestWinner[]

  @@unique([contestId, userId, imageUrl])
  @@index([contestId, status, voteCount])
  @@index([userId, createdAt])
  @@map("photo_contest_entries")
}

model PhotoContestVote {
  id            String            @id @default(cuid())
  entryId       String
  entry         PhotoContestEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  competitionId String
  competition   PhotoContest      @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  userId        String
  ipAddress     String?
  createdAt     DateTime          @default(now())

  @@unique([entryId, userId])
  @@index([competitionId, userId, createdAt])
  @@index([userId, createdAt])
  @@map("photo_contest_votes")
}

model PhotoContestRating {
  id        String            @id @default(cuid())
  entryId   String
  entry     PhotoContestEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  content   String?           @db.Text
  status    String            @default("approved") // approved, hidden
  createdAt DateTime          @default(now())

  @@unique([entryId, userId])
  @@index([entryId, createdAt])
  @@map("photo_contest_ratings")
}

model PhotoContestWinner {
  id               String            @id @default(cuid())
  competitionId    String
  competition      PhotoContest      @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  entryId          String
  entry            PhotoContestEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId           String
  winnerRank       Int
  prizeName        String?
  prizeDescription String?           @db.Text
  prizeValue       String?
  rewardStatus     String            @default("pending") // pending, issued, failed
  remark           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([competitionId, winnerRank])
  @@map("photo_contest_winners")
}

model PhotoContestRegionSetting {
  id                      String   @id @default(cuid())
  regionId                String   @unique
  enableContest           Boolean  @default(true)
  maxCompetitionsPerMonth Int?
  maxPhotosPerUser        Int      @default(3)
  requirePhotoApproval    Boolean  @default(true)
  photoAutoApproval       Boolean  @default(false)
  maxVotesPerUserDaily    Int      @default(10)
  maxVotesPerCompetition  Int?
  maxVotesPerPhoto        Int      @default(1)
  allowSelfVoting         Boolean  @default(false)
  votingIntervalHours     Int?
  watermarkEnabled        Boolean  @default(false)
  watermarkText           String?
  watermarkPosition       String?  // top-left, top-right, bottom-left, bottom-right, center
  enableRating            Boolean  @default(true)
  enableCommenting        Boolean  @default(true)
  adminNotificationEmail  String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("photo_contest_region_settings")
}

model VoteRestrictionLog {
  id            String       @id @default(cuid())
  userId        String
