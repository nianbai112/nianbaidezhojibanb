// ==================== 打卡系统 ====================

enum PunchInCategoryStatus {
  ENABLED
  DISABLED
}

enum PunchInLocationStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum PunchInRecordStatus {
  NORMAL
  DELETED
}

enum PunchInCommentStatus {
  NORMAL
  DELETED
}

enum RankingCycle {
  DAILY
  WEEKLY
  MONTHLY
}

// 地点分类
model PunchInCategory {
  id        String                @id @default(cuid())
  name      String
  icon      String?
  sortOrder Int                   @default(0)
  status    PunchInCategoryStatus @default(ENABLED)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  locations PunchInLocation[]

  @@map("punch_in_categories")
}

// 区域配置
model PunchInConfig {
  id                     String      @id @default(cuid())
  regionId               String      @unique
  isEnabled              Boolean     @default(true)
  maxDailyCheckins       Int         @default(10)
  maxLocationCheckins    Int         @default(3)
  minCheckinInterval     Int         @default(300) // 秒
  allowDuplicateLocation Boolean     @default(true)
  requireLocationVerify  Boolean     @default(false)
  locationVerifyRadius   Int         @default(100) // 米
  allowImageUpload       Boolean     @default(true)
  maxImageCount          Int         @default(9)
  allowVideoUpload       Boolean     @default(true)
  maxContentLength       Int         @default(500)
  requireContent         Boolean     @default(false)
  allowComment           Boolean     @default(true)
  allowReply             Boolean     @default(true)
  maxCommentLength       Int         @default(300)
  enableRanking          Boolean     @default(true)
  rankingCycle           RankingCycle @default(WEEKLY)
  enableSharedLocations  Boolean     @default(true)
  enableUserSuggest      Boolean     @default(true)
  workingHoursStart      String      @default("00:00:00")
  workingHoursEnd        String      @default("23:59:59")
  weekendEnabled         Boolean     @default(true)
  holidayEnabled         Boolean     @default(true)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  @@map("punch_in_configs")
}

// 打卡地点
model PunchInLocation {
  id          String                @id @default(cuid())
  regionId    String
  categoryId  String?
  category    PunchInCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name        String
  description String?
  address     String?
  latitude    Float?
  longitude   Float?
  coverImage  String?
  images      Json?
  videos      Json?
  status      PunchInLocationStatus @default(DRAFT)
  isShared    Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  records  PunchInRecord[]
  comments PunchInComment[]

  @@map("punch_in_locations")
}

// 打卡记录
model PunchInRecord {
  id          String             @id @default(cuid())
  userId      String
  locationId  String?
  location    PunchInLocation?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  regionId    String
  date        String // YYYY-MM-DD
  images      Json?
  content     String?
  status      PunchInRecordStatus @default(NORMAL)
  rewardValue Decimal            @default(0) @db.Decimal(10, 2)
  isMakeup    Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  User        User               @relation(fields: [userId], references: [id])

  @@unique([userId, regionId, date])
  @@map("punch_in_records")
}

// 打卡评论
model PunchInComment {
  id         String               @id @default(cuid())
  userId     String
  User       User                 @relation(fields: [userId], references: [id])
  locationId String
  location   PunchInLocation      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  content    String               @db.Text
  parentId   String?
  parent     PunchInComment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    PunchInComment[]     @relation("CommentReplies")
  status     PunchInCommentStatus @default(NORMAL)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@map("punch_in_comments")
}

