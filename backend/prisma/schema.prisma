  failedReason        String?
  regionId            String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  inviter             User              @relation("InviterRelation", fields: [inviterId], references: [id])
  invitee             User              @relation("InviteeRelation", fields: [inviteeId], references: [id])
