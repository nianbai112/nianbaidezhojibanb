  regionId        String?
  levelNumber     Int
  levelName       String
  levelPrefix     String?
  requiredExp     Int      @default(0)
  isActive        Boolean  @default(true)
  backgroundColor String?
  textColor       String?
  borderColor     String?
  borderWidth     Int?
  borderRadius    Int?
  fontSize        Int?
  fontWeight      String?
  paddingTop      Int?
  paddingBottom   Int?
  paddingLeft     Int?
  paddingRight    Int?
  prefixFontSize  Int?
  prefixTextColor String?
  levelDescription String? @db.Text
  levelBenefits   String?  @db.Text
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([regionId, levelNumber])
  @@map("user_levels")
}

model UserExperience {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  changeAmount Int
  reason       String?
  beforeLevel  String?
  afterLevel   String?
  beforeExp    Int      @default(0)
  afterExp     Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@map("user_experiences")
}

// ==================== 用户标签定义 ====================

model UserTagDefinition {
  id              String   @id @default(cuid())
  regionId        String?
  tagName         String
  tagLevel        Int      @default(1)
  tagColor        String?
  tagDesc         String?
  isSystem        Boolean  @default(false)
  isActive        Boolean  @default(true)
  displayOrder    Int      @default(0)
  backgroundColor String?
  textColor       String?
  borderColor     String?
  borderWidth     Int?
  borderRadius    Int?
  fontSize        Int?
  fontWeight      String?
  paddingTop      Int?
  paddingBottom   Int?
  paddingLeft     Int?
  paddingRight    Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([regionId, tagName])
  @@map("user_tag_definitions")
}

// ==================== 余额操作日志 ====================

model UserBalanceLog {
  id          String   @id @default(cuid())
  operatorId  String
  action      String   // batch_clear, adjust, batch_add, batch_deduct
  userIds     Json     // 批量操作的用户ID列表
  amount      Decimal? @db.Decimal(12, 2)
  reason      String?
  userCount   Int      @default(0)
  totalAmount Decimal? @db.Decimal(12, 2)
  ip          String?
  createdAt   DateTime @default(now())

  @@index([operatorId, createdAt])
  @@index([action, createdAt])
  @@map("user_balance_logs")
}

// ==================== 邮箱配置 ====================

model EmailConfig {
  id             String   @id @default(cuid())
  host           String   @default("smtp.qq.com")
  port           Int      @default(465)
  secure         Boolean  @default(true)
  user           String
  pass           String
  fromEmail      String?
  fromName       String?
  subjectPrefix  String?
  emailSignature String?  @db.Text
  timeout        Int      @default(10000)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("email_configs")
}

// ==================== 微信模板消息 ====================

model WechatTemplateConfig {
  id           String   @id @default(cuid())
  platformType String   @default("miniprogram")
  templateType String
  templateId   String
  defaultPage  String?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([platformType, templateType])
  @@map("wechat_template_configs")
}

// ==================== 小程序页面路径 ====================

model MiniappPage {
  id          String   @id @default(cuid())
  packageName String   @default("main")
  path        String   @unique
  title       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("miniapp_pages")
}

// ==================== 文件上传记录 ====================

model UploadRecord {
  id        String   @id @default(cuid())
  userId    String?
  fileName  String
  fileSize  Int
  fileType  String
  mimeType  String?
  url       String
  scene     String?
  hash      String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([fileType, createdAt])
  @@index([scene, createdAt])
  @@map("upload_records")
}
