  redisStatus   String   @default("unknown") // healthy, degraded, down
  status        String   @default("healthy") // healthy, degraded, down
  detail        Json?
  createdAt     DateTime @default(now())

  @@index([status, createdAt])
  @@map("system_health_snapshots")
}

model ServerActionLog {
  id          String    @id @default(cuid())
  adminId     String
  action      String    // restart_backend, cleanup_logs
  status      String    @default("pending") // pending, success, failed
  reason      String?
  ip          String?
  userAgent   String?
