  detail      Json?
  requestId   String?
  userId      String?
  adminId     String?
  ip          String?
  userAgent   String?
  path        String?
  method      String?
  statusCode  Int?
  durationMs  Int?
  createdAt   DateTime @default(now())

  @@index([level, createdAt])
  @@index([module, createdAt])
  @@index([statusCode, createdAt])
  @@index([path, createdAt])
  @@map("server_logs")
}

model SystemHealthSnapshot {
  id            String   @id @default(cuid())
  cpuUsage      Float    @default(0)
  memoryUsage   Float    @default(0)
  diskUsage     Float    @default(0)
