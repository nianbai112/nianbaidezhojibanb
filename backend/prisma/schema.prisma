// ==================== 分享系统 ====================

enum ShareInviteStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ShareRewardType {
  INVITER
  INVITEE
}

enum ShareRewardStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ShareUserLimit {
  ALL_USERS
  NEW_USERS
}

model ShareSettings {
  id               String          @id @default(cuid())
  regionId         String          @unique
  isEnabled        Boolean         @default(true)
  activityTitle    String?
  activityImage    String?
  activityRules    String?
