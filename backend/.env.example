# 服务器配置
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
# 首次网页安装向导模式：生产首次部署缺配置时可临时设为 true。
# 初始化完成、迁移执行完并确认配置完整后，请删除或改为 false 并重启。
SETUP_WIZARD=false

# 数据库
DATABASE_URL="postgresql://lingmeng:***@localhost:5432/lingmeng_db?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=***

# JWT
JWT_SECRET=super-secret-key-change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# 微信小程序
# 用于获取 access_token 调用 getwxacodeunlimit 生成小程序码
# access_token 自动通过 Redis 缓存 (ttl=expires_in-300s)
WX_MINI_APPID=your-wx-mini-appid
WX_MINI_SECRET=your-wx-mini-secret

# 微信支付
WX_PAY_MCHID=your-mchid
WX_PAY_APIV3_KEY=your-apiv3-key
WX_PAY_CERT_SERIAL_NO=your-cert-serial
WX_PAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WX_PAY_PLATFORM_CERT_PATH=./certs/wechatpay_cert.pem
WX_PAY_NOTIFY_URL=https://your-domain.com/wxpay/notify
WX_PAY_REFUND_NOTIFY_URL=https://your-domain.com/wxpay/refund-notify

# 腾讯云 COS
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=lingmeng-125xxxxxx
COS_REGION=ap-guangzhou
COS_DOMAIN=https://cdn.yuntingzhe.cn

# 阿里云 OSS (可选)
OSS_ACCESS_KEY_ID=your-oss-ak
OSS_ACCESS_KEY_SECRET=***
OSS_BUCKET=lingmeng-bucket
OSS_REGION=oss-cn-hangzhou
OSS_DOMAIN=https://oss.yuntingzhe.cn

# 文件上传限制
UPLOAD_IMAGE_MAX_SIZE_MB=10
UPLOAD_VIDEO_MAX_SIZE_MB=100

# 限流
THROTTLE_TTL=60
THROTTLE_LIMIT=100
# 认证接口（登录/刷新）独立限流，更严格防止暴力破解
AUTH_THROTTLE_LIMIT=5
# 后台管理员登录限流（默认 30 次/分钟）
ADMIN_AUTH_THROTTLE_LIMIT=30

# 运维
OPS_RESTART_COMMAND=""
OPS_RESTART_COOLDOWN_SECONDS=300
OPS_LOG_RETENTION_DAYS=30
